{
  "appId": "com.hilink.dashboard",
  "appName": "لوحة تحكم الراوتر",
  "webDir": "www",
  "backgroundColor": "#0a0e13",
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "CapacitorCookies": {
      "enabled": true
